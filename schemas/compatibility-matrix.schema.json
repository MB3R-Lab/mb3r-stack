{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mb3r.example/schemas/compatibility-matrix.schema.json",
  "title": "MB3R Compatibility Matrix",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "entries"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "stackVersion",
          "beringVersion",
          "sheaftVersion",
          "chartVersion",
          "compatibilityState",
          "evidence",
          "contracts",
          "dashboards",
          "notes"
        ],
        "properties": {
          "stackVersion": {
            "$ref": "#/$defs/versionOrTodo"
          },
          "beringVersion": {
            "$ref": "#/$defs/versionOrTodo"
          },
          "sheaftVersion": {
            "$ref": "#/$defs/versionOrTodo"
          },
          "chartVersion": {
            "$ref": "#/$defs/versionOrTodo"
          },
          "compatibilityState": {
            "type": "string",
            "enum": [
              "todo-verify",
              "candidate",
              "verified",
              "deprecated"
            ]
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "contracts": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/$defs/versionOrTodo"
            }
          },
          "dashboards": {
            "type": "object",
            "required": [
              "bering",
              "sheaft"
            ],
            "properties": {
              "bering": {
                "$ref": "#/$defs/versionOrTodo"
              },
              "sheaft": {
                "$ref": "#/$defs/versionOrTodo"
              }
            },
            "additionalProperties": false
          },
          "notes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "versionOrTodo": {
      "type": "string",
      "pattern": "^(?:\\d+\\.\\d+\\.\\d+(?:[-+][A-Za-z0-9.-]+)?|TODO-[A-Za-z0-9._-]+|v\\d+alpha\\d+)$"
    }
  }
}
