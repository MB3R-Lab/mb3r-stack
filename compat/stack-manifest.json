{
  "$schema": "../schemas/stack-manifest.schema.json",
  "schemaVersion": "1.0.0",
  "stack": {
    "name": "mb3r-stack",
    "version": "0.3.1",
    "status": "candidate",
    "releaseDate": "2026-05-01",
    "notes": [
      "Generic integration and distribution layer only. No upstream Bering or Sheaft source code is vendored here.",
      "Candidate bundle pinned to released Bering v0.3.2 and Sheaft v0.2.2 artifacts with immutable GHCR digests.",
      "OpenTelemetry Demo is packaged as an example profile, not as the core contract.",
      "Bering v0.3.2 keeps the published 1.0.0 and 1.1.0 schema contract lines while adding runtime and toolchain hardening.",
      "Sheaft v0.2.2 strictly validates both the 1.0.0 and 1.1.0 Bering schema lines while keeping serve/watch in technical preview.",
      "Pinned GHCR images are recorded from the upstream release manifests published on 2026-05-01."
    ]
  },
  "artifacts": {
    "chart": {
      "name": "mb3r-stack",
      "version": "0.3.1",
      "ociRepository": "oci://ghcr.io/mb3r-lab/charts",
      "package": "mb3r-stack-0.3.1.tgz"
    },
    "assetPack": {
      "version": "0.3.1",
      "archive": "mb3r-assets-0.3.1.tgz",
      "includes": [
        "collector/",
        "dashboards/",
        "examples/"
      ]
    },
    "dashboards": {
      "bering": "1.0.0",
      "sheaft": "1.0.0"
    },
    "configPacks": {
      "collector": "0.3.1",
      "examples": "0.3.1"
    }
  },
  "components": {
    "bering": {
      "version": "0.3.2",
      "image": {
        "repository": "ghcr.io/mb3r-lab/bering",
        "tag": "v0.3.2",
        "digest": "sha256:98e443461bf59d92cc19b20f425602de91b22a272ecd9a79df5cc20f96c735a8"
      },
      "contracts": {
        "collectorExport": "v1alpha1",
        "discoveryReport": "v1alpha1"
      }
    },
    "sheaft": {
      "version": "0.2.2",
      "image": {
        "repository": "ghcr.io/mb3r-lab/sheaft",
        "tag": "v0.2.2",
        "digest": "sha256:df6a7bbf21e4f307d1d33425f4245eeb34f5d051f46b8ad36ad536b33bf2c331"
      },
      "contracts": {
        "gateDecision": "v1alpha1",
        "reportPayload": "v1alpha1"
      }
    }
  },
  "compatibilityMatrixRef": "compat/compatibility-matrix.json",
  "ownership": {
    "scope": [
      "stack-level compatibility",
      "generic bundle installation",
      "OTLP and artifact integration helpers",
      "profile examples and acceptance assets",
      "dashboards",
      "reusable CI integration adapters"
    ],
    "notInScope": [
      "Bering core discovery logic",
      "Sheaft core simulation logic",
      "application platform source code"
    ]
  }
}
