{
  "$schema": "../schemas/stack-manifest.schema.json",
  "schemaVersion": "1.0.0",
  "stack": {
    "name": "mb3r-stack",
    "version": "0.1.0",
    "status": "candidate",
    "releaseDate": "2026-03-15",
    "notes": [
      "Generic integration and distribution layer only. No upstream Bering or Sheaft source code is vendored here.",
      "Candidate bundle pinned to released Bering v0.1.0 and Sheaft v0.1.1 artifacts with immutable GHCR digests.",
      "Compatibility claims are limited to published contract alignment and packaged integration assets. OpenTelemetry Demo is packaged as an example profile, not as the core contract."
    ]
  },
  "artifacts": {
    "chart": {
      "name": "mb3r-stack",
      "version": "0.1.0",
      "ociRepository": "oci://ghcr.io/mb3r-lab/charts",
      "package": "mb3r-stack-0.1.0.tgz"
    },
    "assetPack": {
      "version": "0.1.0",
      "archive": "mb3r-assets-0.1.0.tgz",
      "includes": [
        "collector/",
        "dashboards/",
        "examples/"
      ]
    },
    "dashboards": {
      "bering": "1.0.0",
      "sheaft": "1.0.0"
    },
    "configPacks": {
      "collector": "0.1.0",
      "examples": "0.1.0"
    }
  },
  "components": {
    "bering": {
      "version": "0.1.0",
      "image": {
        "repository": "ghcr.io/mb3r-lab/bering",
        "tag": "v0.1.0",
        "digest": "sha256:8e8ce6599b43477b0653617e829d41c62a3189d16b60ecb424cca718fc0e2674"
      },
      "contracts": {
        "collectorExport": "v1alpha1",
        "discoveryReport": "v1alpha1"
      }
    },
    "sheaft": {
      "version": "0.1.1",
      "image": {
        "repository": "ghcr.io/mb3r-lab/sheaft",
        "tag": "v0.1.1",
        "digest": "sha256:eb1ebf9d96c55c5bb29e226e07496d152eb3a66b52dd9d34ba799fa4aef70624"
      },
      "contracts": {
        "gateDecision": "v1alpha1",
        "reportPayload": "v1alpha1"
      }
    }
  },
  "compatibilityMatrixRef": "compat/compatibility-matrix.json",
  "ownership": {
    "scope": [
      "stack-level compatibility",
      "generic bundle installation",
      "OTLP and artifact integration helpers",
      "profile examples and acceptance assets",
      "dashboards",
      "reusable CI integration adapters"
    ],
    "notInScope": [
      "Bering core discovery logic",
      "Sheaft core simulation logic",
      "application platform source code"
    ]
  }
}
